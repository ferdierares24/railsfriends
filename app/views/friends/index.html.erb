<% if user_signed_in? %>
<br>
<table class="table table-striped table-hover table-bordered">
  <thead class="table-dark">
    <tr>
      <th>Name</th>
      <th>Email</th>
      <th>Phone</th>
      <th>Twitter</th>
      <!-- <th>User Id</th>  -->
      <th>Actions</th>
    </tr>
  </thead>

  <tbody id="friends">
    <% @friends.each do |friend| %>
      <%= render friend %>
    <% end %>
  </tbody>
</table>

<br>

<%= link_to "New friend", new_friend_path,  class:"btn btn-secondary" %>
<% else %>
  <h1>Hello World!</h1>
  This is my first Rails Webpage....
<% end %>